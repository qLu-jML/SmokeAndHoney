# ── Layout ────────────────────────────────────────────────────────────────────
const VP_W  := 320
const VP_H  := 180
const TOP_H := 16
const BOT_H := 16
const BOT_Y    := VP_H - BOT_H
const HOTBAR_H := 20
const HOTBAR_Y := VP_H - BOT_H - HOTBAR_H   # = 144
const SLOT_W   := 16
const SLOT_H   := 16
const SLOT_GAP := 2
const EBAR_W := 42
const EBAR_H :=  5
const XBAR_W := 50
const XBAR_H :=  3

# ── Colors ────────────────────────────────────────────────────────────────────
const C_TEXT   := Color(0.90, 0.85, 0.70, 1.0)
const C_MUTED  := Color(0.55, 0.50, 0.40, 1.0)
const C_ACCENT := Color(0.95, 0.78, 0.32, 1.0)
