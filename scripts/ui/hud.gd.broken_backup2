	var inner := ColorRect.new()
	inner.color = Color(0.15, 0.10, 0.05, 0.95)
	inner.size  = Vector2(panel_w - 2, panel_h - 2)
	inner.position = Vector2(1, 1)
	inner.mouse_filter = Control.MOUSE_FILTER_IGNORE
