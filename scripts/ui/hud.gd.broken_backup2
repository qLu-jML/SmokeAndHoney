		# Dev mode: auto-advance, skip summary screen
		_on_dev_advance_day()
	else:
		_show_daily_summary()
func _on_season_changed(_s: String) -> void: _refresh_season_icon()
func _on_money_changed(_a: float) -> void: _refresh_money()
func _on_energy_changed(_a: float)-> void: _refresh_energy()
