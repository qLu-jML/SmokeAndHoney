; ═══════════════════════════════════════════════════════════════════════════════
; FLOWER LIFECYCLE MANAGER
; Unified seasonal flower growth, spread, and lifecycle system.
; Each season receives a quality ranking (S/A/B/C/D/F) that affects density
; and spread rate.  Replaces garden beds, wildflower patches, and dandelion
; spawner with organic per-tile flower spawning.
; ═══════════════════════════════════════════════════════════════════════════════

[node name="FlowerLifecycleManager" type="Node2D" parent="World" unique_id=525000001]
script = ExtResource("flower_lifecycle_script")


; ==============================================================================
; FARMSTEAD TREES - drag in editor to reposition, check collision, fix overlap
; Each tree position = trunk base. Sprite draws upward from there.
; y-sort in World node handles draw order (lower y = drawn behind).
; ==============================================================================

[node name="FarmsteadTrees" type="Node2D" parent="World"]
y_sort_enabled = true

; -- WILLOWS (month 0): earliest spring pollen + nectar lifeline --
[node name="WillowCreek1" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(-120, 280)
tree_type = "willow"
flip = false

[node name="WillowCreek2" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(-160, 120)
tree_type = "willow"
flip = true

; -- SILVER MAPLE (month 0): yard shade tree with heavy early pollen --
[node name="SilverMapleYard" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(160, -40)
tree_type = "silver_maple"
flip = false

; -- WILD PLUM (months 0-1): fenceline thicket along west edge --
[node name="WildPlumFence1" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(-100, 400)
tree_type = "wild_plum"
flip = false

[node name="WildPlumFence2" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(-140, 480)
tree_type = "wild_plum"
flip = true

; -- COTTONWOOD (months 0-1): tall windbreak at far north-east --
[node name="CottonwoodWind" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(680, -60)
tree_type = "cottonwood"
flip = false

; -- APPLE TREE (month 1): farmhouse fruit tree, bridges into Greening --
[node name="AppleTreeYard" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(180, -100)
tree_type = "apple_tree"
flip = false

; -- BASSWOOD/LINDEN (months 2-3): premium summer honey tree, far south-east --
[node name="BasswoodSouth" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(820, 450)
tree_type = "basswood_linden"
flip = false

; -- ELM DEAD: atmosphere, no forage -- far south-west --
[node name="ElmDead" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
position = Vector2(-80, 520)
tree_type = "elm_dead"
flip = true

; -- SYCAMORE (months 0-1): minor pollen, nice visual near buildings --
[node name="SycamoreNorth" parent="World/FarmsteadTrees" instance=ExtResource("seasonal_tree_scene")]
